# ATX Transform Platform - Configuration
# Copy to config.env and customize. All settings have defaults.
#
# Used by:
#   - sam/deploy.sh        (reads AWS_REGION, BEDROCK_MODEL_ID)
#   - cdk/deploy.sh        (reads AWS_REGION)
#   - orchestrator/agent.py (reads AWS_REGION, BEDROCK_MODEL_ID at runtime)

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock model for orchestrator + sub-agents
# Options:
#   us.anthropic.claude-sonnet-4-20250514-v1:0   (default, recommended)
#   us.anthropic.claude-sonnet-4-5-20250929-v1:0 (newer, more capable)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Fargate task resources for Batch jobs (optional overrides; CDK defaults match these)
# FARGATE_VCPU=2
# FARGATE_MEMORY=4096

# Max job duration in seconds (default: 43200 = 12 hours)
# JOB_TIMEOUT=43200
