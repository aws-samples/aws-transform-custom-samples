# AWS Transform CLI Deployment Configuration
# Minimal configuration for quick testing

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=  # Auto-detected

# ECR Configuration
# USE_PUBLIC_ECR: Set to "true" to use AWS-provided public ECR image, "false" to build and push to your private ECR
# Public ECR: Faster deployment, no build required, AWS-managed updates
# Private ECR: Full control, custom modifications, security isolation
USE_PUBLIC_ECR=false
PUBLIC_ECR_IMAGE=public.ecr.aws/b7y6j9m3/aws-transform-custom:latest
PUBLIC_ECR_ALIAS=b7y6j9m3

# Resource Names (will auto-append account ID to S3 bucket)
ECR_REPO_NAME=aws-transform-custom
S3_BUCKET_NAME=atx-custom-output
COMPUTE_ENV_NAME=atx-fargate-compute
JOB_QUEUE_NAME=atx-job-queue
JOB_DEFINITION_NAME=atx-transform-job

# Network Configuration (leave empty for auto-detection)
VPC_ID=
SUBNET_IDS=
SECURITY_GROUP_ID=

# Compute Resources
FARGATE_VCPU=2
FARGATE_MEMORY=4096
JOB_TIMEOUT=43200
JOB_RETRY_ATTEMPTS=3

# Advanced Options
ENABLE_ECR_SCANNING=true
LOG_RETENTION_DAYS=30
